# SMTP (fallback until overridden from frontend)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your_gmail_app_password

# Database
DATABASE_URL=sqlite:///./outreachos.db

# Firebase Admin SDK
FIREBASE_SERVICE_ACCOUNT=firebase-service-account.json

# AI providers (fallback until overridden from frontend)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
CEREBRAS_API_KEY=
MISTRAL_API_KEY=

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=https://outreachos.tabcrypt.in
