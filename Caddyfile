# OutreachOS — Caddy reverse proxy config
# Replace outreach.yourdomain.com with your actual domain
# If using Cloudflare Tunnel, set this to your tunnel hostname

outreachos.tabcrypt.in {
    # API — strip /api prefix, proxy to FastAPI backend
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy backend:8000
    }

    # Everything else goes to the React frontend
    handle {
        reverse_proxy frontend:80
    }
}

