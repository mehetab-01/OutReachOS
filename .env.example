# ─── AI Providers ─────────────────────────────────────────────────────────────
# Add any combination — the system uses all available keys in parallel.
# More keys = more lanes = faster batch drafting.

# Google Gemini (free tier): https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq (free tier, 14K req/day on 8B): https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Cerebras (free, 1M tokens/day, ultra-fast): https://cloud.cerebras.ai/
CEREBRAS_API_KEY=your_cerebras_api_key_here

# Mistral AI (free tier, 1B tokens/month): https://console.mistral.ai/
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter (free models available): https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Anthropic Claude (paid): https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# ─── SMTP (Gmail) ────────────────────────────────────────────────────────────
# Generate an App Password at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./outreachos.db
